ARG ROCM_PYTORCH_IMAGE=rocm/pytorch:rocm7.2_ubuntu22.04_py3.10_pytorch_release_2.9.1
FROM ${ROCM_PYTORCH_IMAGE}

WORKDIR /workspace/BreezyVoice

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONUTF8=1 \
    HF_HOME=/root/.cache/huggingface \
    MODEL_PATH=MediaTek-Research/BreezyVoice \
    BREEZYVOICE_DEVICE=rocm \
    BREEZYVOICE_ORT_DEVICE=cpu \
    BREEZYVOICE_USE_TTSFRD=0 \
    BREEZYVOICE_NUM_THREADS=16 \
    BREEZYVOICE_ORT_INTRA_OP_THREADS=8 \
    BREEZYVOICE_ORT_INTER_OP_THREADS=1 \
    BREEZYVOICE_TORCH_BENCHMARK=1 \
    BREEZYVOICE_TORCH_DETERMINISTIC=0 \
    BREEZYVOICE_FLOAT32_MATMUL_PRECISION=high \
    BREEZYVOICE_FLOW_AMP= \
    BREEZYVOICE_HIFT_AMP= \
    BREEZYVOICE_EMPTY_CACHE=0 \
    BREEZYVOICE_LOG_STAGE_TIMINGS=1 \
    BREEZYVOICE_WARMUP=1 \
    BREEZYVOICE_WARMUP_TEXT=你好。 \
    TORCH_ROCM_AOTRITON_ENABLE_EXPERIMENTAL=1 \
    ROCBLAS_USE_HIPBLASLT=0 \
    MIOPEN_FIND_ENFORCE=SEARCH \
    MIOPEN_CUSTOM_CACHE_DIR=/root/.cache/miopen \
    MIOPEN_USER_DB_PATH=/root/.config/miopen \
    MIOPEN_GEMM_ENFORCE_BACKEND=1

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        ffmpeg \
        git \
        libsndfile1 \
        sox \
        libsox-fmt-all && \
    rm -rf /var/lib/apt/lists/*

COPY requirements.runtime.txt requirements.rocm-runtime.txt ./

RUN python -m pip install -r requirements.runtime.txt -r requirements.rocm-runtime.txt

COPY . .

EXPOSE 8080

CMD ["python", "-m", "uvicorn", "api:app", "--host", "0.0.0.0", "--port", "8080"]
